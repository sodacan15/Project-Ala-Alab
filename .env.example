.env.example

# Server configuration
PORT=3001
FRONTEND_PORT=5000
BIND_HOST=127.0.0.1

# Session lifecycle (minutes/seconds)
SESSION_TTL_MINUTES=60
SESSION_GRACE_SECONDS=600

# Git commit behavior when committing confirmed context changes
GIT_COMMIT_ON_CONFIRM=true

# NotebookLM / OAuth configuration (fill when you register your OAuth app)
NOTEBOOKLM_AUTH_URL=https://<provider>/oauth2/authorize
NOTEBOOKLM_TOKEN_URL=https://<provider>/oauth2/token
NOTEBOOKLM_CLIENT_ID=
NOTEBOOKLM_CLIENT_SECRET=
NOTEBOOKLM_REDIRECT_URI=http://127.0.0.1:3001/oauth/callback
