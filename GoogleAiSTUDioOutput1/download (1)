import React, { useState, useEffect } from "react";
import {
  FolderOpen,
  Plus,
  Link2,
  FileUp,
  Image,
  Trash2,
  BookMarked,
  Layers,
  Search,
  CheckCircle,
  XCircle,
  FileText
} from "lucide-react";
import { IndexEntry } from "../types";

export default function Indexer() {
  const [entries, setEntries] = useState<IndexEntry[]>([]);
  const [searchQuery, setSearchQuery] = useState("");
  const [filterType, setFilterType] = useState<"ALL" | "ORIGINAL" | "LINK" | "IMAGE">("ALL");

  // Form toggles and states
  const [activeForm, setActiveForm] = useState<"NONE" | "FILE" | "LINK" | "IMAGE">("NONE");
  
  // ORIGINAL file upload form state
  const [file, setFile] = useState<File | null>(null);
  const [fileDescription, setFileDescription] = useState("");
  const [fileOperator, setFileOperator] = useState("");

  // LINK reference form state
  const [linkUrl, setLinkUrl] = useState("");
  const [linkTitle, setLinkTitle] = useState("");
  const [linkNotes, setLinkNotes] = useState("");
  const [linkOperator, setLinkOperator] = useState("");

  // IMAGE upload form state
  const [imageFile, setImageFile] = useState<File | null>(null);
  const [imageCaption, setImageCaption] = useState("");
  const [imageLinkedEntry, setImageLinkedEntry] = useState("");
  const [imageOperator, setImageOperator] = useState("");

  // Drag and drop states
  const [dragActiveFile, setDragActiveFile] = useState(false);
  const [dragActiveImage, setDragActiveImage] = useState(false);

  const [loading, setLoading] = useState(false);

  const loadEntries = async () => {
    try {
      const res = await fetch("/api/indexer");
      const data = await res.json();
      setEntries(data);
    } catch (err) {
      console.error("Failed to load corpus index entries:", err);
    }
  };

  useEffect(() => {
    loadEntries();
  }, []);

  const handleUploadFile = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!file) {
      alert("Please select a file to upload.");
      return;
    }

    setLoading(true);
    const formData = new FormData();
    formData.append("file", file);
    formData.append("addedBy", fileOperator || "Operator");
    formData.append("description", fileDescription || "No description");

    try {
      const res = await fetch("/api/indexer/upload-file", {
        method: "POST",
        body: formData
      });
      if (res.ok) {
        alert("File uploaded successfully and added to corpus index!");
        setFile(null);
        setFileDescription("");
        setActiveForm("NONE");
        loadEntries();
      } else {
        alert("Failed to upload file.");
      }
    } catch (err) {
      console.error(err);
    } finally {
      setLoading(false);
    }
  };

  const handleAddLink = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!linkUrl || !linkTitle) {
      alert("Please fill in URL and Title.");
      return;
    }

    setLoading(true);
    try {
      const res = await fetch("/api/indexer/add-link", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          url: linkUrl,
          title: linkTitle,
          notes: linkNotes,
          addedBy: linkOperator || "Operator"
        })
      });
      if (res.ok) {
        alert("Link referenced successfully and md wrapper generated!");
        setLinkUrl("");
        setLinkTitle("");
        setLinkNotes("");
        setActiveForm("NONE");
        loadEntries();
      } else {
        alert("Failed to save link reference.");
      }
    } catch (err) {
      console.error(err);
    } finally {
      setLoading(false);
    }
  };

  const handleUploadImage = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!imageFile) {
      alert("Please select an image to load.");
      return;
    }

    setLoading(true);
    const formData = new FormData();
    formData.append("image", imageFile);
    formData.append("addedBy", imageOperator || "Operator");
    formData.append("caption", imageCaption || "No caption");
    formData.append("linkedEntry", imageLinkedEntry || "None");

    try {
      const res = await fetch("/api/indexer/upload-image", {
        method: "POST",
        body: formData
      });
      if (res.ok) {
        alert("Image registered successfully with json metadata!");
        setImageFile(null);
        setImageCaption("");
        setImageLinkedEntry("");
        setActiveForm("NONE");
        loadEntries();
      } else {
        alert("Failed to upload image.");
      }
    } catch (err) {
      console.error(err);
    } finally {
      setLoading(false);
    }
  };

  const handleDelete = async (id: string) => {
    if (!window.confirm("Are you sure you want to delete this archive entry and delete its physical files?")) return;
    try {
      const res = await fetch(`/api/indexer/${id}`, { method: "DELETE" });
      if (res.ok) {
        loadEntries();
      }
    } catch (err) {
      console.error("Failed to delete entry:", err);
    }
  };

  const handleToggleNotebook = async (id: string) => {
    try {
      const res = await fetch(`/api/indexer/${id}/toggle-notebook`, { method: "POST" });
      if (res.ok) {
        loadEntries();
      }
    } catch (err) {
      console.error("Failed to toggle NotebookLM status:", err);
    }
  };

  // Filter & Search logic
  const filteredEntries = entries.filter(e => {
    const matchesType = filterType === "ALL" || e.type === filterType;
    
    const searchStr = searchQuery.toLowerCase();
    const matchesSearch = e.type === "LINK"
      ? (e as any).title.toLowerCase().includes(searchStr) || (e as any).url.toLowerCase().includes(searchStr)
      : e.filename.toLowerCase().includes(searchStr) || (e as any).addedBy.toLowerCase().includes(searchStr);

    return matchesType && matchesSearch;
  });

  return (
    <div className="max-w-7xl mx-auto p-4 md:p-6 space-y-6">
      {/* HEADER BAR */}
      <div className="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 bg-sand-200 border border-loam-300 p-5 rounded-2xl shadow-sm">
        <div>
          <h1 className="text-2xl font-display font-bold text-clay-900 tracking-tight flex items-center gap-2">
            <FolderOpen className="text-rust-500 w-6 h-6" />
            Corpus Indexer & Archival Manager
          </h1>
          <p className="text-xs font-sans text-silt-600 mt-1">
            Register and link bottom-up community narratives, official files, and images into the master index `corpus-index.md`.
          </p>
        </div>
        <div className="flex flex-wrap gap-2">
          <button
            onClick={() => setActiveForm(activeForm === "FILE" ? "NONE" : "FILE")}
            className="bg-white hover:bg-sand-100 border border-loam-300 text-clay-900 px-3 py-1.5 rounded-lg text-xs font-mono uppercase flex items-center gap-1.5 cursor-pointer"
          >
            <FileUp className="w-4 h-4 text-rust-500" />
            + File (ORIGINAL)
          </button>
          <button
            onClick={() => setActiveForm(activeForm === "LINK" ? "NONE" : "LINK")}
            className="bg-white hover:bg-sand-100 border border-loam-300 text-clay-900 px-3 py-1.5 rounded-lg text-xs font-mono uppercase flex items-center gap-1.5 cursor-pointer"
          >
            <Link2 className="w-4 h-4 text-stone-600" />
            + Web Link (LINK)
          </button>
          <button
            onClick={() => setActiveForm(activeForm === "IMAGE" ? "NONE" : "IMAGE")}
            className="bg-white hover:bg-sand-100 border border-loam-300 text-clay-900 px-3 py-1.5 rounded-lg text-xs font-mono uppercase flex items-center gap-1.5 cursor-pointer"
          >
            <Image className="w-4 h-4 text-sage-600" />
            + Image (IMAGE)
          </button>
        </div>
      </div>

      {/* RENDER FORM BASED ON TOGGLE */}
      {activeForm !== "NONE" && (
        <div className="bg-white border border-loam-300 p-5 rounded-2xl shadow-sm">
          {/* FILE FORM */}
          {activeForm === "FILE" && (
            <form onSubmit={handleUploadFile} className="space-y-4">
              <h3 className="text-xs font-mono font-bold uppercase tracking-wider text-rust-500 flex items-center gap-1">
                <FileUp className="w-4 h-4" /> Upload Raw File into Archive
              </h3>
              <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                  <label className="block text-xs font-mono text-silt-600 uppercase mb-1">Select File</label>
                  <div
                    onDragOver={(e) => { e.preventDefault(); e.stopPropagation(); setDragActiveFile(true); }}
                    onDragEnter={(e) => { e.preventDefault(); e.stopPropagation(); setDragActiveFile(true); }}
                    onDragLeave={(e) => { e.preventDefault(); e.stopPropagation(); setDragActiveFile(false); }}
                    onDrop={(e) => {
                      e.preventDefault();
                      e.stopPropagation();
                      setDragActiveFile(false);
                      if (e.dataTransfer.files && e.dataTransfer.files[0]) {
                        setFile(e.dataTransfer.files[0]);
                      }
                    }}
                    className={`border-2 border-dashed rounded-lg p-3 text-center transition-all duration-150 cursor-pointer ${
                      dragActiveFile
                        ? "border-rust-500 bg-sand-200"
                        : file
                        ? "border-emerald-500 bg-emerald-50/20"
                        : "border-loam-300 hover:border-rust-400 bg-sand-50"
                    }`}
                    onClick={() => {
                      const el = document.getElementById("file-input-field");
                      if (el) el.click();
                    }}
                  >
                    <input
                      id="file-input-field"
                      type="file"
                      onChange={(e) => setFile(e.target.files ? e.target.files[0] : null)}
                      className="hidden"
                    />
                    <div className="text-[11px] font-mono text-clay-900 font-semibold mb-1 truncate max-w-xs mx-auto">
                      {file ? `📎 ${file.name}` : "Drag & Drop File Here"}
                    </div>
                    <div className="text-[10px] text-silt-500 font-sans">
                      {file ? "Click to change" : "or click to browse"}
                    </div>
                  </div>
                </div>
                <div>
                  <label className="block text-xs font-mono text-silt-600 uppercase mb-1">Operator Code</label>
                  <input
                    type="text"
                    placeholder="e.g. OP-VALENZUELA"
                    value={fileOperator}
                    onChange={(e) => setFileOperator(e.target.value)}
                    className="w-full p-2 text-xs bg-sand-100 border border-loam-300 rounded-lg text-clay-900 focus:outline-none"
                  />
                </div>
                <div>
                  <label className="block text-xs font-mono text-silt-600 uppercase mb-1">Archival Description</label>
                  <input
                    type="text"
                    placeholder="e.g. Master flood control blueprint map"
                    value={fileDescription}
                    onChange={(e) => setFileDescription(e.target.value)}
                    className="w-full p-2 text-xs bg-sand-100 border border-loam-300 rounded-lg text-clay-900 focus:outline-none"
                  />
                </div>
              </div>
              <div className="flex justify-end gap-2">
                <button
                  type="button"
                  onClick={() => setActiveForm("NONE")}
                  className="px-3 py-1.5 border border-loam-300 rounded-lg text-xs font-mono uppercase cursor-pointer"
                >
                  Cancel
                </button>
                <button
                  type="submit"
                  disabled={loading}
                  className="px-4 py-1.5 bg-rust-500 hover:bg-rust-600 text-white rounded-lg text-xs font-mono uppercase cursor-pointer"
                >
                  {loading ? "Archiving..." : "Archive File"}
                </button>
              </div>
            </form>
          )}

          {/* LINK FORM */}
          {activeForm === "LINK" && (
            <form onSubmit={handleAddLink} className="space-y-4">
              <h3 className="text-xs font-mono font-bold uppercase tracking-wider text-rust-500 flex items-center gap-1">
                <Link2 className="w-4 h-4" /> Link Web/Reference Entry
              </h3>
              <div className="grid grid-cols-1 md:grid-cols-4 gap-4">
                <div className="md:col-span-2">
                  <label className="block text-xs font-mono text-silt-600 uppercase mb-1">Source URL</label>
                  <input
                    type="url"
                    placeholder="https://valenzuela.gov.ph/drainage-report"
                    value={linkUrl}
                    onChange={(e) => setLinkUrl(e.target.value)}
                    className="w-full p-2 text-xs bg-sand-100 border border-loam-300 rounded-lg text-clay-900 focus:outline-none"
                  />
                </div>
                <div>
                  <label className="block text-xs font-mono text-silt-600 uppercase mb-1">Source Title</label>
                  <input
                    type="text"
                    placeholder="e.g. Drainage Master Plan"
                    value={linkTitle}
                    onChange={(e) => setLinkTitle(e.target.value)}
                    className="w-full p-2 text-xs bg-sand-100 border border-loam-300 rounded-lg text-clay-900 focus:outline-none"
                  />
                </div>
                <div>
                  <label className="block text-xs font-mono text-silt-600 uppercase mb-1">Operator Code</label>
                  <input
                    type="text"
                    placeholder="e.g. OP-VALENZUELA"
                    value={linkOperator}
                    onChange={(e) => setLinkOperator(e.target.value)}
                    className="w-full p-2 text-xs bg-sand-100 border border-loam-300 rounded-lg text-clay-900 focus:outline-none"
                  />
                </div>
                <div className="md:col-span-4">
                  <label className="block text-xs font-mono text-silt-600 uppercase mb-1">Socio-ecological notes</label>
                  <input
                    type="text"
                    placeholder="Documenting official links for NotebookLM retrieval..."
                    value={linkNotes}
                    onChange={(e) => setLinkNotes(e.target.value)}
                    className="w-full p-2 text-xs bg-sand-100 border border-loam-300 rounded-lg text-clay-900 focus:outline-none"
                  />
                </div>
              </div>
              <div className="flex justify-end gap-2">
                <button
                  type="button"
                  onClick={() => setActiveForm("NONE")}
                  className="px-3 py-1.5 border border-loam-300 rounded-lg text-xs font-mono uppercase cursor-pointer"
                >
                  Cancel
                </button>
                <button
                  type="submit"
                  disabled={loading}
                  className="px-4 py-1.5 bg-rust-500 hover:bg-rust-600 text-white rounded-lg text-xs font-mono uppercase cursor-pointer"
                >
                  {loading ? "Generating Wrapper..." : "Save Web Reference"}
                </button>
              </div>
            </form>
          )}

          {/* IMAGE FORM */}
          {activeForm === "IMAGE" && (
            <form onSubmit={handleUploadImage} className="space-y-4">
              <h3 className="text-xs font-mono font-bold uppercase tracking-wider text-rust-500 flex items-center gap-1">
                <Image className="w-4 h-4" /> Load Physical Photo/Image
              </h3>
              <div className="grid grid-cols-1 md:grid-cols-4 gap-4">
                <div>
                  <label className="block text-xs font-mono text-silt-600 uppercase mb-1">Select Image</label>
                  <div
                    onDragOver={(e) => { e.preventDefault(); e.stopPropagation(); setDragActiveImage(true); }}
                    onDragEnter={(e) => { e.preventDefault(); e.stopPropagation(); setDragActiveImage(true); }}
                    onDragLeave={(e) => { e.preventDefault(); e.stopPropagation(); setDragActiveImage(false); }}
                    onDrop={(e) => {
                      e.preventDefault();
                      e.stopPropagation();
                      setDragActiveImage(false);
                      if (e.dataTransfer.files && e.dataTransfer.files[0]) {
                        setImageFile(e.dataTransfer.files[0]);
                      }
                    }}
                    className={`border-2 border-dashed rounded-lg p-3 text-center transition-all duration-150 cursor-pointer ${
                      dragActiveImage
                        ? "border-rust-500 bg-sand-200"
                        : imageFile
                        ? "border-emerald-500 bg-emerald-50/20"
                        : "border-loam-300 hover:border-rust-400 bg-sand-50"
                    }`}
                    onClick={() => {
                      const el = document.getElementById("image-input-field");
                      if (el) el.click();
                    }}
                  >
                    <input
                      id="image-input-field"
                      type="file"
                      accept="image/*"
                      onChange={(e) => setImageFile(e.target.files ? e.target.files[0] : null)}
                      className="hidden"
                    />
                    <div className="text-[11px] font-mono text-clay-900 font-semibold mb-1 truncate max-w-xs mx-auto">
                      {imageFile ? `🖼️ ${imageFile.name}` : "Drag & Drop Image Here"}
                    </div>
                    <div className="text-[10px] text-silt-500 font-sans">
                      {imageFile ? "Click to change" : "or click to browse"}
                    </div>
                  </div>
                </div>
                <div>
                  <label className="block text-xs font-mono text-silt-600 uppercase mb-1">Photo Caption</label>
                  <input
                    type="text"
                    placeholder="e.g. Flooded Victoria Village street gates"
                    value={imageCaption}
                    onChange={(e) => setImageCaption(e.target.value)}
                    className="w-full p-2 text-xs bg-sand-100 border border-loam-300 rounded-lg text-clay-900 focus:outline-none"
                  />
                </div>
                <div>
                  <label className="block text-xs font-mono text-silt-600 uppercase mb-1">Linked Context Header</label>
                  <input
                    type="text"
                    placeholder="e.g. Victoria Village Flood Level"
                    value={imageLinkedEntry}
                    onChange={(e) => setImageLinkedEntry(e.target.value)}
                    className="w-full p-2 text-xs bg-sand-100 border border-loam-300 rounded-lg text-clay-900 focus:outline-none"
                  />
                </div>
                <div>
                  <label className="block text-xs font-mono text-silt-600 uppercase mb-1">Operator Code</label>
                  <input
                    type="text"
                    placeholder="e.g. OP-VALENZUELA"
                    value={imageOperator}
                    onChange={(e) => setImageOperator(e.target.value)}
                    className="w-full p-2 text-xs bg-sand-100 border border-loam-300 rounded-lg text-clay-900 focus:outline-none"
                  />
                </div>
              </div>
              <div className="flex justify-end gap-2">
                <button
                  type="button"
                  onClick={() => setActiveForm("NONE")}
                  className="px-3 py-1.5 border border-loam-300 rounded-lg text-xs font-mono uppercase cursor-pointer"
                >
                  Cancel
                </button>
                <button
                  type="submit"
                  disabled={loading}
                  className="px-4 py-1.5 bg-rust-500 hover:bg-rust-600 text-white rounded-lg text-xs font-mono uppercase cursor-pointer"
                >
                  {loading ? "Uploading..." : "Save Image Asset"}
                </button>
              </div>
            </form>
          )}
        </div>
      )}

      {/* FILTER & SEARCH */}
      <div className="flex flex-col md:flex-row gap-4 justify-between items-center bg-white border border-loam-300 p-4 rounded-xl shadow-sm">
        {/* Search */}
        <div className="relative w-full md:w-80">
          <span className="absolute inset-y-0 left-0 pl-3 flex items-center text-silt-500">
            <Search className="w-4 h-4" />
          </span>
          <input
            type="text"
            placeholder="Search corpus index..."
            value={searchQuery}
            onChange={(e) => setSearchQuery(e.target.value)}
            className="w-full pl-9 pr-4 py-1.5 text-xs bg-sand-100 border border-loam-300 rounded-lg text-clay-900 focus:outline-none"
          />
        </div>

        {/* Filters */}
        <div className="flex gap-1.5 overflow-x-auto w-full md:w-auto">
          {(["ALL", "ORIGINAL", "LINK", "IMAGE"] as const).map(type => (
            <button
              key={type}
              onClick={() => setFilterType(type)}
              className={`px-3 py-1.5 rounded-lg text-[10px] font-mono font-bold uppercase transition-colors cursor-pointer shrink-0 ${
                filterType === type
                  ? "bg-rust-500 text-white"
                  : "bg-sand-100 hover:bg-sand-200 text-silt-600"
              }`}
            >
              {type}
            </button>
          ))}
        </div>
      </div>

      {/* CORPUS DATA TABLE */}
      <div className="bg-white border border-loam-300 rounded-2xl shadow-sm overflow-hidden">
        {filteredEntries.length === 0 ? (
          <div className="text-center py-12">
            <FileText className="w-10 h-10 text-loam-300 mx-auto mb-2" />
            <p className="text-xs text-silt-500 italic">No archive entries found matching active parameters.</p>
          </div>
        ) : (
          <div className="overflow-x-auto">
            <table className="w-full text-left border-collapse text-xs">
              <thead>
                <tr className="border-b border-loam-300 bg-sand-100 text-silt-500 font-mono uppercase tracking-wider">
                  <th className="p-3">Type</th>
                  <th className="p-3">Asset Identification / Name</th>
                  <th className="p-3">Grounded in NotebookLM</th>
                  <th className="p-3">Archived Date</th>
                  <th className="p-3">Archived By</th>
                  <th className="p-3">Actions</th>
                </tr>
              </thead>
              <tbody className="divide-y divide-sand-200">
                {filteredEntries.map(e => (
                  <tr key={e.id} className="hover:bg-sand-50 transition-colors">
                    {/* TYPE ACCENT */}
                    <td className="p-3 font-mono font-bold text-[10px]">
                      <span className={`px-2 py-0.5 rounded ${
                        e.type === "ORIGINAL" ? "bg-rust-500/10 text-rust-500 border border-rust-500/20" :
                        e.type === "LINK" ? "bg-stone-600/10 text-stone-600 border border-stone-600/20" :
                        "bg-sage-600/10 text-sage-600 border border-sage-600/20"
                      }`}>
                        {e.type}
                      </span>
                    </td>

                    {/* NAME / DETAILS */}
                    <td className="p-3 font-sans">
                      {e.type === "LINK" ? (
                        <div className="space-y-0.5">
                          <span className="font-semibold text-clay-900 block font-mono text-xs">{(e as any).title}</span>
                          <a
                            href={(e as any).url}
                            target="_blank"
                            rel="noopener noreferrer"
                            className="text-[10px] text-stone-600 underline font-mono truncate block max-w-sm"
                          >
                            {(e as any).url}
                          </a>
                          <span className="text-[10px] text-silt-500 block">Notes: {(e as any).notes}</span>
                        </div>
                      ) : e.type === "IMAGE" ? (
                        <div className="flex items-center gap-3">
                          <img
                            src={`/storage/images/${e.filename}`}
                            alt={e.filename}
                            className="w-12 h-12 object-cover rounded-lg border border-loam-300 bg-sand-100/50 shrink-0 shadow-xs"
                            referrerPolicy="no-referrer"
                            onError={(evt) => {
                              evt.currentTarget.style.display = "none";
                            }}
                          />
                          <div className="space-y-0.5">
                            <span className="font-semibold text-clay-900 block font-mono text-xs">{e.filename}</span>
                            <span className="text-[10px] text-silt-500 block">Caption: {(e as any).caption}</span>
                            <span className="text-[10px] text-silt-500 block">Anchor Header: {(e as any).linkedEntry}</span>
                          </div>
                        </div>
                      ) : (
                        <div className="space-y-0.5">
                          <span className="font-semibold text-clay-900 block font-mono text-xs">{e.filename}</span>
                          <span className="text-[10px] text-silt-500 block">Desc: {(e as any).description}</span>
                        </div>
                      )}
                    </td>

                    {/* TOGGLE NOTEBOOK STATUS */}
                    <td className="p-3">
                      <button
                        onClick={() => handleToggleNotebook(e.id)}
                        className={`flex items-center gap-1.5 px-3 py-1 rounded-full font-mono text-[10px] font-bold uppercase transition-all duration-150 border cursor-pointer ${
                          e.inNotebook
                            ? "bg-sage-600 text-white border-sage-600 hover:bg-sage-600/90"
                            : "bg-white text-silt-500 border-loam-300 hover:bg-sand-100"
                        }`}
                      >
                        {e.inNotebook ? (
                          <>
                            <CheckCircle className="w-3.5 h-3.5" />
                            Grounded
                          </>
                        ) : (
                          <>
                            <XCircle className="w-3.5 h-3.5 text-loam-300" />
                            Load to Notebook
                          </>
                        )}
                      </button>
                    </td>

                    {/* ARCHIVED DATE */}
                    <td className="p-3 font-mono text-silt-500">{e.dateAdded}</td>

                    {/* OPERATOR */}
                    <td className="p-3 font-mono font-semibold text-clay-900">{(e as any).addedBy}</td>

                    {/* ACTIONS */}
                    <td className="p-3">
                      <button
                        onClick={() => handleDelete(e.id)}
                        className="p-1.5 text-ochre-600 hover:bg-ochre-600/10 rounded-lg transition-colors cursor-pointer"
                        title="Delete asset"
                      >
                        <Trash2 className="w-4 h-4" />
                      </button>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>

      {/* INTEGRATION SUMMARY FOOTER */}
      <div className="bg-sand-200 border border-loam-300 p-4 rounded-xl flex items-center gap-3">
        <Layers className="w-5 h-5 text-rust-500 shrink-0" />
        <p className="text-[11px] text-silt-600">
          All indices synchronized with `src/storage/corpus-index.md` and wrapped automatically. 
          Use checkboxes to dictate which pieces of evidence pass to agent prompts for robust grounding.
        </p>
      </div>
    </div>
  );
}
