import React, { useState, useEffect } from "react";
import {
  FileText,
  Search,
  Plus,
  Compass,
  BookOpen,
  Calendar,
  Layers,
  Activity,
  User,
  CheckCircle2
} from "lucide-react";
import { ContextMetadata } from "../types";

export default function Context() {
  const [contexts, setContexts] = useState<ContextMetadata[]>([]);
  const [selectedContext, setSelectedContext] = useState<ContextMetadata | null>(null);
  const [markdownContent, setMarkdownContent] = useState<string>("");
  const [searchQuery, setSearchQuery] = useState("");
  const [loading, setLoading] = useState(false);

  // Form states for creating a new context file
  const [showCreateForm, setShowCreateForm] = useState(false);
  const [newContextName, setNewContextName] = useState("");
  const [newContextScope, setNewContextScope] = useState("Barangay");
  const [newContextDescription, setNewContextDescription] = useState("");

  const loadContexts = async (selectFirst = false) => {
    try {
      const res = await fetch("/api/contexts");
      const data = await res.json();
      setContexts(data);
      
      if (data.length > 0 && (selectFirst || !selectedContext)) {
        handleSelectContext(data[0]);
      }
    } catch (err) {
      console.error("Failed to load contexts:", err);
    }
  };

  const handleSelectContext = async (meta: ContextMetadata) => {
    setSelectedContext(meta);
    setLoading(true);
    try {
      const res = await fetch(`/api/contexts/${meta.filename}`);
      const data = await res.json();
      setMarkdownContent(data.markdown || "");
    } catch (err) {
      console.error("Error reading context file:", err);
    } finally {
      setLoading(false);
    }
  };

  useEffect(() => {
    loadContexts(true);
  }, []);

  const handleCreateContext = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!newContextName || !newContextDescription) {
      alert("Please fill out name and description.");
      return;
    }

    try {
      const res = await fetch("/api/contexts/new", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          name: newContextName,
          scope: newContextScope,
          description: newContextDescription
        })
      });
      const data = await res.json();
      if (res.ok) {
        alert(`Success! Created new Context file: ${data.filename}. Clean session initialized!`);
        setNewContextName("");
        setNewContextDescription("");
        setShowCreateForm(false);
        loadContexts();
      } else {
        alert(`Error: ${data.error}`);
      }
    } catch (err) {
      console.error("Failed to create context:", err);
    }
  };

  const filteredContexts = contexts.filter(c =>
    c.name.toLowerCase().includes(searchQuery.toLowerCase()) ||
    c.description.toLowerCase().includes(searchQuery.toLowerCase()) ||
    c.scope.toLowerCase().includes(searchQuery.toLowerCase())
  );

  return (
    <div className="max-w-7xl mx-auto p-4 md:p-6 space-y-6">
      {/* HEADER SECTION */}
      <div className="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 bg-sand-200 border border-loam-300 p-5 rounded-2xl shadow-sm">
        <div>
          <h1 className="text-2xl font-display font-bold text-clay-900 tracking-tight flex items-center gap-2">
            <BookOpen className="text-rust-500 w-6 h-6" />
            Barangay Context File Explorer
          </h1>
          <p className="text-xs font-sans text-silt-600 mt-1">
            Access, view, and provision the `.md` context scaffolds coordinating Victoria Village historical memories.
          </p>
        </div>
        <button
          onClick={() => setShowCreateForm(!showCreateForm)}
          className="bg-rust-500 hover:bg-rust-600 text-white px-4 py-2 rounded-lg text-xs font-mono uppercase tracking-wider flex items-center gap-1.5 transition-colors cursor-pointer"
        >
          <Plus className="w-4 h-4" />
          {showCreateForm ? "Cancel Creation" : "Create Context Document"}
        </button>
      </div>

      {/* CREATE NEW CONTEXT FORM PANEL */}
      {showCreateForm && (
        <form onSubmit={handleCreateContext} className="bg-white border border-loam-300 p-6 rounded-2xl shadow-sm space-y-4">
          <h2 className="text-sm font-mono font-bold uppercase tracking-wider text-rust-500 border-b border-sand-200 pb-2">
            Provision New Living Context Document
          </h2>
          <p className="text-xs text-silt-500">
            Note: Provisioning a new context document triggers the **Session Pre-Reset Sequence**. 
            This safely updates the current session history into the active context and archives active prompts.
          </p>

          <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div className="md:col-span-2">
              <label className="block text-xs font-mono text-silt-600 uppercase mb-1">Context Name / Location</label>
              <input
                type="text"
                placeholder="e.g. Victoria Village Flood Record"
                value={newContextName}
                onChange={(e) => setNewContextName(e.target.value)}
                className="w-full p-2.5 text-xs bg-sand-100 border border-loam-300 rounded-lg text-clay-900 focus:outline-none"
              />
            </div>
            <div>
              <label className="block text-xs font-mono text-silt-600 uppercase mb-1">Scope Scale</label>
              <select
                value={newContextScope}
                onChange={(e) => setNewContextScope(e.target.value)}
                className="w-full p-2.5 text-xs bg-sand-100 border border-loam-300 rounded-lg text-clay-900 focus:outline-none"
              >
                <option value="Barangay">Barangay</option>
                <option value="Purok">Purok</option>
                <option value="Municipal">Municipal</option>
                <option value="Household">Household</option>
              </select>
            </div>
            <div className="md:col-span-3">
              <label className="block text-xs font-mono text-silt-600 uppercase mb-1">Archival Description</label>
              <textarea
                placeholder="Describe the scope, ecological significance, and goals of this context document..."
                value={newContextDescription}
                onChange={(e) => setNewContextDescription(e.target.value)}
                rows={3}
                className="w-full p-2.5 text-xs bg-sand-100 border border-loam-300 rounded-lg text-clay-900 focus:outline-none"
              />
            </div>
          </div>

          <div className="flex justify-end pt-2">
            <button
              type="submit"
              className="bg-sage-600 hover:bg-sage-600/90 text-white px-5 py-2 rounded-lg text-xs font-mono uppercase cursor-pointer"
            >
              PROVISION & LAUNCH FRESH SESSION
            </button>
          </div>
        </form>
      )}

      {/* EXPLORER PANELS */}
      <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {/* LEFT COLUMN: LIST PANEL */}
        <div className="bg-white border border-loam-300 p-5 rounded-2xl shadow-sm space-y-4 lg:col-span-1">
          {/* SEARCH BOX */}
          <div className="relative">
            <span className="absolute inset-y-0 left-0 pl-3 flex items-center text-silt-500">
              <Search className="w-4 h-4" />
            </span>
            <input
              type="text"
              placeholder="Search context entries..."
              value={searchQuery}
              onChange={(e) => setSearchQuery(e.target.value)}
              className="w-full pl-9 pr-4 py-2 text-xs bg-sand-100 border border-loam-300 rounded-lg text-clay-900 focus:outline-none"
            />
          </div>

          {/* FILE LIST */}
          <div className="space-y-3 max-h-[500px] overflow-y-auto pr-1">
            {filteredContexts.map(meta => (
              <div
                key={meta.filename}
                onClick={() => handleSelectContext(meta)}
                className={`p-4 border rounded-xl cursor-pointer transition-all duration-150 text-left ${
                  selectedContext?.filename === meta.filename
                    ? "bg-rust-500/5 border-rust-500"
                    : "bg-sand-50/50 border-loam-300 hover:bg-sand-100"
                }`}
              >
                <div className="flex items-start gap-2.5">
                  <FileText className={`w-4 h-4 shrink-0 mt-0.5 ${
                    selectedContext?.filename === meta.filename ? "text-rust-500" : "text-silt-500"
                  }`} />
                  <div className="space-y-1">
                    <span className="text-xs font-mono font-bold text-clay-900 block leading-tight">
                      {meta.name}
                    </span>
                    <span className="text-[10px] font-mono text-silt-500 block">
                      Scope: <span className="text-ochre-600 font-semibold">{meta.scope}</span> | v{meta.version}
                    </span>
                    <p className="text-[11px] font-sans text-silt-600 line-clamp-2 pt-1 leading-snug">
                      {meta.description}
                    </p>
                  </div>
                </div>
              </div>
            ))}
            {filteredContexts.length === 0 && (
              <div className="text-center py-6 text-xs text-silt-500 italic">
                No contexts match filter.
              </div>
            )}
          </div>
        </div>

        {/* RIGHT COLUMN: READ PANEL */}
        <div className="lg:col-span-2 bg-white border border-loam-300 p-5 rounded-2xl shadow-sm h-[650px] flex flex-col justify-between overflow-hidden">
          {selectedContext ? (
            <>
              {/* Context Detail Metadata Panel */}
              <div className="bg-sand-100/80 p-4 border border-loam-300 rounded-xl space-y-2 mb-4 shrink-0">
                <div className="flex flex-wrap justify-between items-center gap-2 border-b border-loam-300 pb-2">
                  <span className="text-xs font-mono font-bold text-clay-900 flex items-center gap-1">
                    <Compass className="w-4 h-4 text-rust-500" />
                    FILE: {selectedContext.filename}
                  </span>
                  <span className="bg-sage-600/10 text-sage-600 px-2 py-0.5 rounded text-[10px] font-mono font-bold uppercase flex items-center gap-1">
                    <CheckCircle2 className="w-3 h-3" /> ACTIVE FILE SYSTEM
                  </span>
                </div>
                <div className="grid grid-cols-2 md:grid-cols-4 gap-3 text-[10px] font-mono text-silt-600">
                  <div>
                    <span className="text-silt-500 uppercase block">Created</span>
                    <span className="font-semibold text-clay-900 flex items-center gap-1">
                      <Calendar className="w-3 h-3 text-silt-500" />
                      {selectedContext.created}
                    </span>
                  </div>
                  <div>
                    <span className="text-silt-500 uppercase block">Last Updated</span>
                    <span className="font-semibold text-clay-900 flex items-center gap-1">
                      <Layers className="w-3 h-3 text-silt-500" />
                      {selectedContext.lastUpdated}
                    </span>
                  </div>
                  <div>
                    <span className="text-silt-500 uppercase block">Version</span>
                    <span className="font-semibold text-clay-900">{selectedContext.version}</span>
                  </div>
                  <div>
                    <span className="text-silt-500 uppercase block">Archivist Role</span>
                    <span className="font-semibold text-clay-900 flex items-center gap-1">
                      <User className="w-3 h-3 text-silt-500" />
                      System Operator
                    </span>
                  </div>
                </div>
              </div>

              {/* Full Content Markdown Viewer */}
              <div className="flex-1 overflow-y-auto bg-sand-50/20 border border-loam-300 rounded-xl p-5 font-mono text-xs text-clay-900 leading-relaxed whitespace-pre-wrap">
                {loading ? (
                  <div className="flex justify-center items-center h-full">
                    <span className="pulse-glow">Loading markdown context stream...</span>
                  </div>
                ) : (
                  markdownContent
                )}
              </div>
            </>
          ) : (
            <div className="flex flex-col justify-center items-center h-full text-center text-silt-500 bg-sand-50/50 rounded-xl border border-dashed border-loam-300 p-6">
              <BookOpen className="w-12 h-12 text-loam-300 mb-3" />
              <h3 className="font-display font-bold text-sm text-clay-900">No active Context file opened.</h3>
              <p className="text-xs mt-1 max-w-sm">
                Select a context document from the left-hand explorer sidebar to load its living memory.
              </p>
            </div>
          )}
        </div>
      </div>
    </div>
  );
}
